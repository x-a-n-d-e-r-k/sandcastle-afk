#!/usr/bin/env bash
# forge — a thin, forge-agnostic adapter over `gh` (GitHub) and `glab` (GitLab).
#
# The orchestrator (loop.ts etc.) AND the agent prompts call `forge <verb>`,
# never `gh`/`glab` directly. Swap platforms by setting FORGE_PLATFORM.
# Identity is whatever token is in the environment when forge is called
# (e.g. `GH_TOKEN="$REVIEW_TOKEN" forge pr-approve 5` posts as the reviewer).
#
#   FORGE_PLATFORM = github | gitlab   (required)
#
# Normalized review state (pr-list / pr-review-state): APPROVED | CHANGES_REQUESTED | REVIEW_REQUIRED
#
# Requires: jq, and gh (github) or glab (gitlab).
set -euo pipefail

PLATFORM="${FORGE_PLATFORM:-github}"
verb="${1:-}"; shift || true

die() { echo "forge: $*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1"; }
need jq

case "$PLATFORM" in
  github) need gh ;;
  gitlab) need glab ;;
  *) die "unknown FORGE_PLATFORM '$PLATFORM' (expected github|gitlab)" ;;
esac

# ---- arg helpers -----------------------------------------------------------
# Collect repeated --label values and pass-through of common flags.
labels=(); title=""; body=""; body_file=""; base=""; comment=""; state="open"
add_labels=(); rm_labels=(); new_title=""; POS=(); SQUASH=0; DELBR=0; REVIEWER=0; NOAUTO=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --label) labels+=("$2"); shift 2 ;;
    --add-label) add_labels+=("$2"); shift 2 ;;
    --remove-label) rm_labels+=("$2"); shift 2 ;;
    --title) title="$2"; shift 2 ;;
    --new-title) new_title="$2"; shift 2 ;;
    --body) body="$2"; shift 2 ;;
    --body-file) body_file="$2"; shift 2 ;;
    --base) base="$2"; shift 2 ;;
    --comment) comment="$2"; shift 2 ;;
    --state) state="$2"; shift 2 ;;
    --squash) SQUASH=1; shift ;;
    --delete-branch) DELBR=1; shift ;;
    --as-reviewer) REVIEWER=1; shift ;;
    --no-auto-merge) NOAUTO=1; shift ;;
    *) POS+=("$1"); shift ;;
  esac
done

# --as-reviewer: run this call under the reviewer identity (FORGE_REVIEW_TOKEN),
# so an approval is not attributed to the PR/MR author.
if [[ "${REVIEWER:-0}" == 1 ]]; then
  : "${FORGE_REVIEW_TOKEN:?--as-reviewer requires FORGE_REVIEW_TOKEN in the environment}"
  if [[ "$PLATFORM" == github ]]; then export GH_TOKEN="$FORGE_REVIEW_TOKEN"
  else export GITLAB_TOKEN="$FORGE_REVIEW_TOKEN"; export GLAB_TOKEN="$FORGE_REVIEW_TOKEN"; fi
fi
NUM="${POS[0]:-}"
CHANGES_LABEL="changes-requested"   # GitLab convention for "request changes"

# Build per-platform label flags
gh_label_flags() { local f=(); for l in "$@"; do f+=(--label "$l"); done; printf '%s\n' "${f[@]}"; }
csv() { local IFS=,; echo "$*"; }

# gitlab: echo "<project_id> <iid> <head_pipeline_id>" for MR number $1 (pipeline id may be empty)
gl_ctx() {
  local mr pid iid pip
  mr="$(glab mr view "$1" -F json)"
  pid="$(jq -r '.project_id' <<<"$mr")"; iid="$(jq -r '.iid' <<<"$mr")"
  pip="$(glab api "projects/$pid/merge_requests/$iid" 2>/dev/null | jq -r '.head_pipeline.id // empty')"
  echo "$pid $iid $pip"
}

# --- transient-error retry --------------------------------------------------
# GitHub/GitLab intermittently return transient infra errors (5xx gateway,
# service-unavailable, timeouts, secondary rate limits). Retry READ verbs with
# exponential backoff so a momentary blip doesn't fail the caller (e.g. burn an
# AFK loop cycle). MUTATING verbs are NOT retried — a retry after a partial write
# could double-apply (duplicate comment/label/merge). Tunable via FORGE_MAX_RETRIES
# and FORGE_RETRY_BASE_SECONDS (base 0 => instant backoff, used by the tests).
FORGE_MAX_RETRIES="${FORGE_MAX_RETRIES:-4}"
FORGE_RETRY_BASE_SECONDS="${FORGE_RETRY_BASE_SECONDS:-2}"
TRANSIENT_RE='HTTP 5[0-9][0-9]|bad gateway|gateway time|service unavailable|internal server error|temporarily unavailable|handshake timeout|i/o timeout|client\.timeout|timed out|timeout|connection reset|connection refused|\beof\b|secondary rate limit|abuse detection|try again'

is_retryable_verb() {
  case "$1" in
    issue-list|issue-view|pr-list|pr-view|pr-diff|pr-changes-count|pr-pipeline|pr-pipeline-failed-jobs|pr-pipeline-failures|pr-pipeline-retry-count|pr-has-conflicts|pr-conflict-retry-count|pr-feedback) return 0 ;;
    *) return 1 ;;
  esac
}

# The verb dispatch. run_with_retry runs it in a `( set -e; dispatch )` subshell
# so its fail-fast (set -e + pipefail) semantics are preserved while the caller
# captures the exit code and stderr to decide whether to retry.
dispatch() {
case "$verb" in
  # ---------- issues ----------
  issue-list)
    if [[ "$PLATFORM" == github ]]; then
      args=(issue list --state "$state" --json number,title,labels --limit 200)
      [[ ${#labels[@]} -gt 0 ]] && while read -r f; do args+=("$f"); done < <(gh_label_flags "${labels[@]}")
      gh "${args[@]}" | jq '[.[] | {number, title, labels: [.labels[].name]}]'
    else
      # glab `issue list`: state is --opened/--closed/--all (no --state); JSON is --output (not -F).
      gl=(); case "$state" in closed) gl=(--closed);; all) gl=(--all);; esac
      lbl=(); [[ ${#labels[@]} -gt 0 ]] && lbl=(--label "$(csv "${labels[@]}")")
      glab issue list ${gl[@]+"${gl[@]}"} ${lbl[@]+"${lbl[@]}"} --output json \
        | jq '[.[] | {number: .iid, title, labels: (.labels // [])}]'
    fi ;;

  issue-view)
    [[ -n "$NUM" ]] || die "issue-view needs <number>"
    # `state` (lowercased open/closed) feeds the loop's blocker-sweep isClosed check —
    # it MUST be emitted or the sweep never unblocks anything. gh returns OPEN/CLOSED;
    # glab returns opened/closed. Normalize both to open/closed.
    if [[ "$PLATFORM" == github ]]; then
      gh issue view "$NUM" --json number,title,body,labels,state | jq '{number, title, body, labels: [.labels[].name], state: (.state | ascii_downcase)}'
    else
      glab issue view "$NUM" -F json | jq '{number: .iid, title, body: (.description // ""), labels: (.labels // []), state: (if .state == "closed" then "closed" else "open" end)}'
    fi ;;

  issue-create)
    [[ -n "$title" && -n "$body_file" ]] || die "issue-create needs --title and --body-file"
    if [[ "$PLATFORM" == github ]]; then
      args=(issue create --title "$title" --body-file "$body_file")
      while read -r f; do args+=("$f"); done < <(gh_label_flags "${labels[@]}")
      gh "${args[@]}"
    else
      glab issue create --title "$title" --description "$(cat "$body_file")" \
        $( [[ ${#labels[@]} -gt 0 ]] && echo --label "$(csv "${labels[@]}")" ) --yes
    fi ;;

  issue-edit)
    [[ -n "$NUM" ]] || die "issue-edit needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      args=(issue edit "$NUM"); [[ -n "$body_file" ]] && args+=(--body-file "$body_file")
      [[ -n "$new_title" ]] && args+=(--title "$new_title")
      for l in "${add_labels[@]:-}"; do [[ -n "$l" ]] && args+=(--add-label "$l"); done
      for l in "${rm_labels[@]:-}"; do [[ -n "$l" ]] && args+=(--remove-label "$l"); done
      gh "${args[@]}"
    else
      args=(issue update "$NUM"); [[ -n "$body_file" ]] && args+=(--description "$(cat "$body_file")")
      [[ -n "$new_title" ]] && args+=(--title "$new_title")
      [[ ${#add_labels[@]:-0} -gt 0 ]] && args+=(--label "$(csv "${add_labels[@]}")")
      [[ ${#rm_labels[@]:-0} -gt 0 ]] && args+=(--unlabel "$(csv "${rm_labels[@]}")")
      glab "${args[@]}"
    fi ;;

  issue-close)
    [[ -n "$NUM" ]] || die "issue-close needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      gh issue close "$NUM" $( [[ -n "$comment" ]] && echo --comment "$comment" )
    else
      [[ -n "$comment" ]] && glab issue note "$NUM" -m "$comment" || true
      glab issue close "$NUM"
    fi ;;

  # ---------- pull / merge requests ----------
  pr-create)
    [[ -n "$base" && -n "$title" ]] || die "pr-create needs --base and --title"
    if [[ "$PLATFORM" == github ]]; then
      gh pr create --base "$base" --title "$title" --body "$body"
    else
      glab mr create --source-branch "$(git branch --show-current)" --target-branch "$base" \
        --title "$title" --description "$body" --yes --remove-source-branch
    fi ;;

  pr-list)
    if [[ "$PLATFORM" == github ]]; then
      gh pr list --state "$state" --json number,headRefName,reviewDecision,labels,state --limit 100 \
        | jq '[.[] | {number, headRef: .headRefName, merged: (.state == "MERGED"),
              reviewState: (.reviewDecision | if . == "" or . == null then "REVIEW_REQUIRED" else . end),
              labels: [.labels[].name]}]'
    else
      # glab `mr list` state is flag-based and does NOT include approval fields.
      # Query the per-MR /approvals endpoint and FAIL CLOSED: APPROVED only when an
      # approval RULE is satisfied (approvals_required>0 && approvals_left==0) — so a
      # project with no approval rule never auto-merges unreviewed.
      gl=(); case "$state" in closed) gl=(--closed);; merged) gl=(--merged);; all) gl=(--all);; esac
      glab mr list ${gl[@]+"${gl[@]}"} -F json | jq -c '.[]' | while read -r mr; do
        iid=$(jq -r '.iid' <<<"$mr"); pid=$(jq -r '.project_id' <<<"$mr")
        appr="$(glab api "projects/$pid/merge_requests/$iid/approvals" 2>/dev/null || echo '{}')"
        jq -n --argjson mr "$mr" --argjson appr "$appr" --arg cr "$CHANGES_LABEL" '
          ($mr.labels // []) as $l |
          {number: $mr.iid, headRef: $mr.source_branch, merged: ($mr.state == "merged"), labels: $l,
           reviewState: (
             if ($l | index($cr)) then "CHANGES_REQUESTED"
             elif (($appr.approvals_required // 0) > 0 and ($appr.approvals_left // 1) == 0) then "APPROVED"
             else "REVIEW_REQUIRED" end)}'
      done | jq -s '.'
    fi ;;

  pr-view)
    [[ -n "$NUM" ]] || die "pr-view needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      gh pr view "$NUM" --json number,title,body,headRefName,baseRefName \
        | jq '{number, title, body, headRef: .headRefName, baseRef: .baseRefName}'
    else
      glab mr view "$NUM" -F json \
        | jq '{number: .iid, title, body: (.description // ""), headRef: .source_branch, baseRef: .target_branch}'
    fi ;;

  pr-diff)
    [[ -n "$NUM" ]] || die "pr-diff needs <number>"
    if [[ "$PLATFORM" == github ]]; then gh pr diff "$NUM"; else glab mr diff "$NUM"; fi ;;

  pr-approve)
    [[ -n "$NUM" ]] || die "pr-approve needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      gh pr review "$NUM" --approve $( [[ -n "$body" ]] && echo --body "$body" )
    else
      glab mr approve "$NUM"
      [[ -n "$body" ]] && glab mr note "$NUM" -m "$body" || true
    fi ;;

  pr-request-changes)
    [[ -n "$NUM" ]] || die "pr-request-changes needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      gh pr review "$NUM" --request-changes --body "${body:-Changes requested.}"
    else
      # GitLab has no native "request changes": mark with a label + a marked comment.
      glab label create "$CHANGES_LABEL" --color "#D93F0B" 2>/dev/null || true
      glab mr update "$NUM" --label "$CHANGES_LABEL"
      glab mr note "$NUM" -m "[forge:changes-requested] ${body:-Changes requested.}"
    fi ;;

  pr-changes-count)
    [[ -n "$NUM" ]] || die "pr-changes-count needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      gh pr view "$NUM" --json reviews | jq '[.reviews[] | select(.state=="CHANGES_REQUESTED")] | length'
    else
      glab mr note list "$NUM" -F json 2>/dev/null | jq '[.[].notes[]? | select(.body | startswith("[forge:changes-requested]"))] | length' 2>/dev/null || echo 0
    fi ;;

  pr-clear-changes)  # called after a heal push, to reset the gitlab label
    [[ -n "$NUM" ]] || die "pr-clear-changes needs <number>"
    if [[ "$PLATFORM" == gitlab ]]; then glab mr update "$NUM" --unlabel "$CHANGES_LABEL" 2>/dev/null || true; fi ;;

  pr-merge)
    [[ -n "$NUM" ]] || die "pr-merge needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      gh pr merge "$NUM" $( [[ "${SQUASH}" == 1 ]] && echo --squash ) $( [[ "${DELBR}" == 1 ]] && echo --delete-branch )
    else
      glab mr merge "$NUM" $( [[ "${SQUASH}" == 1 ]] && echo --squash ) $( [[ "${DELBR}" == 1 ]] && echo --remove-source-branch ) $( [[ "${NOAUTO}" == 1 ]] && echo --auto-merge=false ) --yes
    fi ;;

  pr-label)
    [[ -n "$NUM" ]] || die "pr-label needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      args=(pr edit "$NUM")
      for l in "${add_labels[@]:-}"; do [[ -n "$l" ]] && args+=(--add-label "$l"); done
      for l in "${rm_labels[@]:-}"; do [[ -n "$l" ]] && args+=(--remove-label "$l"); done
      gh "${args[@]}"
    else
      args=(mr update "$NUM")
      [[ ${#add_labels[@]:-0} -gt 0 ]] && args+=(--label "$(csv "${add_labels[@]}")")
      [[ ${#rm_labels[@]:-0} -gt 0 ]] && args+=(--unlabel "$(csv "${rm_labels[@]}")")
      glab "${args[@]}"
    fi ;;

  pr-comment)
    [[ -n "$NUM" ]] || die "pr-comment needs <number>"
    if [[ "$PLATFORM" == github ]]; then gh pr comment "$NUM" --body "$body"; else glab mr note "$NUM" -m "$body"; fi ;;

  pr-pipeline)  # -> {status, id}; status in success|running|pending|failed|canceled|skipped|none
    [[ -n "$NUM" ]] || die "pr-pipeline needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      # VERIFY (gh): roll up the status-check rollup
      gh pr view "$NUM" --json statusCheckRollup,headRefOid | jq '
        (.statusCheckRollup // []) as $c | { id: .headRefOid, status: (
          if ($c|length)==0 then "none"
          elif ($c|any(((.conclusion // "")) as $x | ($x=="FAILURE" or $x=="TIMED_OUT" or $x=="CANCELLED" or $x=="STARTUP_FAILURE"))) then "failed"
          elif ($c|any(((.status // "")) as $x | ($x=="IN_PROGRESS" or $x=="QUEUED" or $x=="PENDING" or $x=="WAITING"))) then "running"
          else "success" end) }'
    else
      read -r pid iid _ < <(gl_ctx "$NUM")
      glab api "projects/$pid/merge_requests/$iid" | jq '
        (.head_pipeline) as $p | { id: ($p.id // null), status: (
          if $p == null then "none"
          else ($p.status) as $s |
            if $s=="success" then "success" elif $s=="failed" then "failed"
            elif $s=="canceled" then "canceled" elif $s=="skipped" then "skipped"
            else "running" end end) }'
    fi ;;

  pr-pipeline-retry)  # retry failed/canceled jobs in the head pipeline
    [[ -n "$NUM" ]] || die "pr-pipeline-retry needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      rid="$(gh run list --branch "$(gh pr view "$NUM" --json headRefName -q .headRefName)" --json databaseId -L 1 -q '.[0].databaseId' 2>/dev/null)"
      [[ -n "$rid" ]] && gh run rerun "$rid" --failed && echo "rerun $rid" || echo "(no run to retry)"
    else
      read -r pid iid pip < <(gl_ctx "$NUM")
      [[ -n "$pip" ]] && glab api --method POST "projects/$pid/pipelines/$pip/retry" >/dev/null && echo "retried pipeline $pip" || echo "(no pipeline to retry)"
    fi ;;

  pr-pipeline-failed-jobs)  # newline-separated failed job names (for the flaky-job check)
    [[ -n "$NUM" ]] || die "pr-pipeline-failed-jobs needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      rid="$(gh run list --branch "$(gh pr view "$NUM" --json headRefName -q .headRefName)" --json databaseId -L 1 -q '.[0].databaseId' 2>/dev/null)"
      [[ -n "$rid" ]] && gh run view "$rid" --json jobs | jq -r '.jobs[] | select(.conclusion=="failure") | .name' || true
    else
      read -r pid iid pip < <(gl_ctx "$NUM")
      [[ -n "$pip" ]] && glab api "projects/$pid/pipelines/$pip/jobs?scope=failed" | jq -r '.[].name' || true
    fi ;;

  pr-pipeline-failures)  # failed job names + trace tails, for the heal prompt
    [[ -n "$NUM" ]] || die "pr-pipeline-failures needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      rid="$(gh run list --branch "$(gh pr view "$NUM" --json headRefName -q .headRefName)" --json databaseId -L 1 -q '.[0].databaseId' 2>/dev/null)"
      [[ -n "$rid" ]] && gh run view "$rid" --log-failed 2>/dev/null | tail -200 || echo "(no failed logs)"
    else
      read -r pid iid pip < <(gl_ctx "$NUM")
      if [[ -z "$pip" ]]; then echo "(no pipeline)"; else
        glab api "projects/$pid/pipelines/$pip/jobs?scope=failed" | jq -r '.[].id' | while read -r jid; do
          echo "### FAILED JOB: $(glab api "projects/$pid/jobs/$jid" | jq -r '.name')"
          glab api "projects/$pid/jobs/$jid/trace" 2>/dev/null | tail -60; echo
        done
      fi
    fi ;;

  pr-pipeline-retry-count)  # count of [forge:pipeline-retry] markers (stateless retry budget)
    [[ -n "$NUM" ]] || die "pr-pipeline-retry-count needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      gh pr view "$NUM" --json comments | jq '[.comments[] | select(.body | startswith("[forge:pipeline-retry]"))] | length'
    else
      glab mr note list "$NUM" -F json 2>/dev/null | jq '[.[].notes[]? | select(.body | startswith("[forge:pipeline-retry]"))] | length' 2>/dev/null || echo 0
    fi ;;

  pr-pipeline-retry-mark)  # record one retry attempt
    [[ -n "$NUM" ]] || die "pr-pipeline-retry-mark needs <number>"
    if [[ "$PLATFORM" == github ]]; then gh pr comment "$NUM" --body "[forge:pipeline-retry]"; else glab mr note "$NUM" -m "[forge:pipeline-retry]"; fi ;;

  pr-has-conflicts)  # "true" if the PR/MR has merge conflicts with its target branch, else "false"
    [[ -n "$NUM" ]] || die "pr-has-conflicts needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      gh pr view "$NUM" --json mergeable | jq -r 'if .mergeable == "CONFLICTING" then "true" else "false" end'
    else
      read -r pid iid _ < <(gl_ctx "$NUM")
      glab api "projects/$pid/merge_requests/$iid" | jq -r '.has_conflicts // false'
    fi ;;

  pr-conflict-retry-count)  # count of [forge:conflict-retry] markers (stateless conflict-resolve budget)
    [[ -n "$NUM" ]] || die "pr-conflict-retry-count needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      gh pr view "$NUM" --json comments | jq '[.comments[] | select(.body | startswith("[forge:conflict-retry]"))] | length'
    else
      glab mr note list "$NUM" -F json 2>/dev/null | jq '[.[].notes[]? | select(.body | startswith("[forge:conflict-retry]"))] | length' 2>/dev/null || echo 0
    fi ;;

  pr-conflict-retry-mark)  # record one conflict-resolve attempt
    [[ -n "$NUM" ]] || die "pr-conflict-retry-mark needs <number>"
    if [[ "$PLATFORM" == github ]]; then gh pr comment "$NUM" --body "[forge:conflict-retry]"; else glab mr note "$NUM" -m "[forge:conflict-retry]"; fi ;;

  git-setup)  # configure git push credentials for the current platform's token
    if [[ "$PLATFORM" == github ]]; then
      git config --global credential.helper '!f() { echo username=x-access-token; echo "password=$GH_TOKEN"; }; f'
    else
      git config --global credential.helper '!f() { echo username=oauth2; echo "password=${GITLAB_TOKEN:-$GLAB_TOKEN}"; }; f'
    fi ;;

  pr-feedback)  # ALL reviewer feedback (review summaries + inline threads + comments), for heal
    [[ -n "$NUM" ]] || die "pr-feedback needs <number>"
    if [[ "$PLATFORM" == github ]]; then
      {
        gh pr view "$NUM" --json reviews \
          | jq -r '.reviews[] | select((.body // "") != "") | "### review by \(.author.login) [\(.state)]\n\(.body)\n"'
        gh api "repos/{owner}/{repo}/pulls/${NUM}/comments" 2>/dev/null \
          | jq -r '.[] | "### inline @ \(.path):\(.line // .original_line) (\(.user.login))\n\(.body)\n"' 2>/dev/null || true
        gh pr view "$NUM" --json comments \
          | jq -r '.comments[] | "### comment by \(.author.login)\n\(.body)\n"'
      }
    else
      glab mr note list "$NUM" -F json 2>/dev/null \
        | jq -r '.[].notes[]? | select((.system // false) | not) | "### note by \(.author.username // "?")\n\(.body)\n"'
    fi ;;

  *) die "unknown verb '$verb'. See bin/forge for the verb list." ;;
esac
}

# Run the verb; on a transient error from a READ verb, retry with exponential
# backoff. stdout is buffered so a failed attempt never emits partial output.
run_with_retry() {
  local out err rc attempt=0 delay
  out="$(mktemp)"; err="$(mktemp)"
  while :; do
    set +e; ( set -e; dispatch ) >"$out" 2>"$err"; rc=$?; set -e
    if [[ "$rc" -eq 0 ]]; then cat "$out"; rm -f "$out" "$err"; return 0; fi
    if is_retryable_verb "$verb" && [[ "$attempt" -lt "$FORGE_MAX_RETRIES" ]] && grep -qiE "$TRANSIENT_RE" "$err"; then
      attempt=$((attempt + 1))
      delay=$(( FORGE_RETRY_BASE_SECONDS * (2 ** (attempt - 1)) ))
      { echo "forge: transient error on '$verb' (attempt ${attempt}/${FORGE_MAX_RETRIES}); retrying in ${delay}s"; cat "$err"; } >&2
      sleep "$delay"
      continue
    fi
    cat "$err" >&2; rm -f "$out" "$err"; return "$rc"
  done
}

run_with_retry
