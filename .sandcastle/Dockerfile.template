# Rendered by `pnpm afk:init` into .sandcastle/Dockerfile. Edit the template,
# not the output (re-run init to regenerate). Assumes a Node-based image; for
# other stacks, adjust the base image and the agent-user block.
FROM {{BASE_IMAGE}}

RUN apt-get update && apt-get install -y git curl jq ca-certificates && rm -rf /var/lib/apt/lists/*

# Forge CLI (gh for GitHub, glab for GitLab)
{{FORGE_CLI_INSTALL}}

# Package manager pre-bake (so corepack doesn't download the pinned version at runtime)
{{PM_PREBAKE}}

ARG AGENT_UID=1000
ARG AGENT_GID=1000
RUN groupmod -o -g $AGENT_GID node && usermod -o -u $AGENT_UID -g $AGENT_GID -d /home/agent -m -l agent node
USER ${AGENT_UID}:${AGENT_GID}

# Claude Code CLI
RUN curl -fsSL https://claude.ai/install.sh | bash

# `forge` rides in on the bind-mounted worktree at /home/agent/workspace/bin
ENV PATH="/home/agent/workspace/bin:/home/agent/.local/bin:$PATH"
ENV FORGE_PLATFORM={{PLATFORM}}

WORKDIR /home/agent
ENTRYPOINT ["sleep", "infinity"]
