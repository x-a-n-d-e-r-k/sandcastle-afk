  "pr-merge":                 { "mutating": true,  "retryable": false, "output": "none", "requiredArgs": ["number"] },
  "pr-label":                 { "mutating": true,  "retryable": false, "output": "none", "requiredArgs": ["number"] },
  "pr-comment":               { "mutating": true,  "retryable": false, "output": "none", "requiredArgs": ["number"] },
  "pr-feedback":              { "mutating": false, "retryable": true,  "output": "text", "requiredArgs": ["number"] },

