# Copy to .sandcastle/.env and fill in. This file is gitignored.

# --- Claude (the agent) ---
# Use your Claude subscription: run `claude setup-token` and paste the result.
CLAUDE_CODE_OAUTH_TOKEN=
# ...or an API key instead (uncomment):
# ANTHROPIC_API_KEY=

# --- Forge identity: IMPLEMENTER (dev-agent) ---
# GitHub: a fine-grained PAT (Contents RW, Pull requests RW, Issues RW, Metadata R)
#         for a bot account that is a write collaborator.
GH_TOKEN=
# GitLab: a project/personal access token (api, write_repository) for the dev bot.
# GITLAB_TOKEN=

# --- Forge identity: REVIEWER (review-agent, MUST be a different account) ---
# Used by `forge ... --as-reviewer` so approvals aren't attributed to the author.
FORGE_REVIEW_TOKEN=

# Set automatically from afk.config.json by the runners; only override to force it.
# FORGE_PLATFORM=github
